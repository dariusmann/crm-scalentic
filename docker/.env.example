# Twenty Docker image tag — pin a specific release, not "latest" in production.
# Find tags: https://github.com/twentyhq/twenty/releases
# Docker Hub is the source of truth for self-host versions.
TAG=v2.14.0

# Database
PG_DATABASE_USER=postgres
PG_DATABASE_PASSWORD=replace_me_with_a_strong_password_without_special_characters
PG_DATABASE_HOST=db
PG_DATABASE_PORT=5432
PG_DATABASE_NAME=default

REDIS_URL=redis://redis:6379

# Local development
SERVER_URL=http://localhost:3000

# Production — uncomment and set your public URL (must match how users access the app)
# SERVER_URL=https://crm.yourdomain.com

# Generate each secret with: openssl rand -base64 32
# Keep ENCRYPTION_KEY secret — losing it means losing access to stored OAuth tokens and secrets.
ENCRYPTION_KEY=replace_me_with_a_random_string
# FALLBACK_ENCRYPTION_KEY=  # set to the previous ENCRYPTION_KEY during key rotation
# APP_SECRET=                # legacy: only required for instances that pre-date ENCRYPTION_KEY

STORAGE_TYPE=local

# Leave unset for default server behavior
# DISABLE_DB_MIGRATIONS=
# DISABLE_CRON_JOBS_REGISTRATION=

# S3 storage (optional, for production)
# STORAGE_S3_REGION=eu-west-3
# STORAGE_S3_NAME=my-bucket
# STORAGE_S3_ENDPOINT=
# STORAGE_S3_ACCESS_KEY_ID=
# STORAGE_S3_SECRET_ACCESS_KEY=
